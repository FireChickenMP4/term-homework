{
    email admin@firechickenmp4.top
}

www.firechickenmp4.top {
    rate_limit {
        zone dynamic {
            key {remote_host}
            events 100
            window 1m
        }
    }

    handle /api/* {
        reverse_proxy app:8808
    }

    handle {
        root * /usr/share/caddy
        try_files {path} /index.html
        file_server
    }
}
